{
  "name": "flowstate-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:full": "concurrently -k \"npm run serve\" \"npm run dev\"",
    "serve": "bash ../scripts/dev-server.sh",
    "build": "vue-tsc && vite build",
    "preview": "vite preview",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "typecheck": "vue-tsc --noEmit"
  },
  "dependencies": {
    "fuzzysort": "^3.1.0",
    "markdown-it": "^14.1.1",
    "pinia": "^2.1.7",
    "vue": "^3.4.0",
    "vue-router": "^4.2.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^20.10.0",
    "@vitejs/plugin-vue": "^6.0.0",
    "@vue/test-utils": "^2.4.10",
    "concurrently": "^8.2.0",
    "jsdom": "^29.1.1",
    "typescript": "^5.3.2",
    "vite": "^8.0.10",
    "vitest": "^4.1.5",
    "vue-tsc": "^3.2.7"
  }
}
